# ─── 이 파일은 커밋됨 (실키 넣지 말 것). 실키는 server/.env 로 복사해서 채운다 ───
#   cp server/.env.example server/.env  후 값 입력
#
# Letsur AI Gateway — 실 OCR(Vision LLM) 및 AI 산출물용
#   가이드: https://platform.letsur.ai/guide
#   Base URL: https://gw.letsur.ai  (OpenAI/Anthropic 호환)
#   인증: Authorization: Bearer $LETSUR_API_KEY  (Anthropic 네이티브는 x-api-key)
#
# ocr.js가 POST /api/receipts 의 업로드 이미지를 인식할 때 이 키를 읽어
# https://gw.letsur.ai/v1/chat/completions 로 호출한다.
# 하이브리드 동작:
#   · 실제 이미지 업로드 → 키 필요. 없거나 인식 실패 시 저장하지 않고 명확한 OCR 오류 반환(폴백 금지).
#   · 데모 샘플칩(JSON {key}) → fixtures/receipts-ocr WoZ 픽스처로 키 없이도 동작(데모 재현 유지).
LETSUR_API_KEY=
LETSUR_BASE_URL=https://gw.letsur.ai
OCR_MODEL=gpt-4o
OCR_TIMEOUT_MS=30000

# Supabase 영구 저장 — 미설정 시 로컬 개발은 기존 인메모리 모드
# Secret key(sb_secret_...)는 서버 전용이며 브라우저·GitHub에 노출하지 않는다.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_BUCKET=receipt-images
SUPABASE_STATE_ID=main
